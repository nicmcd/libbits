prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: libbits
Description: A simple C++ library containing bit twiddling functions.
URL: https://github.com/nicmcd/libbits
Version: 0.1.0
Requires: libprim
Libs: -L${libdir} -lbits 
Cflags: -I${includedir}
